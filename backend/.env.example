# ===== FlowOS backend environment (copy to .env and fill in) =====

# ---- Server ----
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
CORS_ORIGIN=*

# ---- MongoDB ----
# Local:  mongodb://127.0.0.1:27017/flowos
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/flowos
MONGODB_URI=mongodb://127.0.0.1:27017/flowos

# ---- JWT ----
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ---- Email (password reset, staff invites) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="FlowOS <no-reply@flowos.app>"

# ---- AI Assistant (Groq, OpenAI-compatible) ----
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Firebase Cloud Messaging (future push) ----
# Path to the service-account JSON; leave blank until FCM is wired.
FIREBASE_SERVICE_ACCOUNT_PATH=

# ---- File uploads (local-disk storage in dev) ----
UPLOAD_DIR=./uploads
