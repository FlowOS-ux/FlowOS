# ==================================================================================
#  FlowOS backend environment — copy this file to .env and fill in your values.
#  (.env is gitignored; never commit real secrets.)
#
#  For the DEPLOYED app, set the same variable names in the Render dashboard
#  (flowos-backend ▸ Environment) — this file only affects local development.
#
#  LEGEND:  [REQUIRED]      app will not boot without it
#           [REQUIRED-PROD] needed on Render for friends to use the app
#           [OPTIONAL]      feature is skipped gracefully when blank
# ==================================================================================


# ---- Server --------------------------------------------------------------------
# [REQUIRED] Leave as-is for local development.
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
# CORS: * is fine locally. On Render, set this to the flowos-web URL after deploy.
CORS_ORIGIN=*
# Reverse-proxy hops in front of the app (Render = 1, Railway = 2; irrelevant locally).
TRUST_PROXY=1


# ---- Database ------------------------------------------------------------------
# [REQUIRED] Local mongod, or a MongoDB Atlas connection string:
#   mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/flowos?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/flowos


# ---- JWT secrets ---------------------------------------------------------------
# [REQUIRED] Random strings, 16+ chars (32+ recommended), different from each other.
# On Render these are auto-generated by the blueprint.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string
JWT_REFRESH_EXPIRES_IN=30d


# ---- Admin account (used ONLY by the seed scripts) ------------------------------
# [REQUIRED to run `npm run seed` or `npm run seed:demo`]
# The platform-admin login the seed creates. Pick your own email + a strong password.
ADMIN_EMAIL=
ADMIN_PASSWORD=


# ---- Email (verification codes + password reset) --------------------------------
# Provider precedence (first one configured wins):
#   GOOGLE_REFRESH_TOKEN > BREVO_API_KEY > RESEND_API_KEY > MAILJET keys > SMTP
# If ALL are blank: "console" demo mode — the OTP is returned by the API and shown
# in-app, so Register -> Verify -> Login still works with no email delivery.
#
# [REQUIRED-PROD] Configure exactly ONE provider below.

# Option A — Gmail SMTP with an App Password
#   1. Google account: enable 2-Step Verification.
#   2. Create an App Password: https://myaccount.google.com/apppasswords
#   3. SMTP_USER = the Gmail address.  SMTP_PASS = the 16-char app password
#      WITHOUT SPACES (Google displays "abcd efgh ijkl mnop" — type "abcdefghijklmnop").
#   4. Use SMTP_HOST=smtp.gmail.com and SMTP_PORT=465.
#   5. EMAIL_FROM must be the same Gmail address.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="FlowOS <no-reply@flowos.app>"

# Option B — Brevo HTTP API (recommended on Render: 300 free emails/day,
#   works even where SMTP ports are restricted).
#   1. https://www.brevo.com -> verify a sender address.
#   2. Settings -> SMTP & API -> API Keys -> create a v3 key (starts with xkeysib-).
#   3. Paste it below and set EMAIL_FROM to the verified sender.
BREVO_API_KEY=

# Option C — Resend HTTP API (free test mode only delivers to YOUR OWN signup email;
#   EMAIL_FROM must be "FlowOS <onboarding@resend.dev>" unless you verify a domain).
RESEND_API_KEY=

# Option D — Mailjet HTTP API (needs BOTH keys; sender must be validated in Mailjet).
MAILJET_API_KEY=
MAILJET_SECRET_KEY=

# Option E — Gmail API via OAuth2 (advanced; needs all three Google values).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=


# ---- AI assistant (Groq) ---------------------------------------------------------
# [OPTIONAL] Free key at https://console.groq.com (starts with gsk_).
# Blank = the AI assistant replies with a graceful fallback.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile


# ---- Push notifications (Firebase Cloud Messaging) -------------------------------
# [OPTIONAL] Absolute path to the Firebase service-account JSON file.
# Blank = push is a silent no-op (in-app + realtime notifications still work).
FIREBASE_SERVICE_ACCOUNT_PATH=


# ---- File uploads -----------------------------------------------------------------
# [OPTIONAL] Local folder for uploaded images. Note: on Render's free tier this disk
# is wiped on every deploy/restart — uploaded images are temporary there.
UPLOAD_DIR=./uploads
