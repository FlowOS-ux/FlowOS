{
  "name": "flowos-backend",
  "version": "0.1.0",
  "description": "FlowOS backend API — virtual queue management platform (Express + MongoDB).",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev:db": "tsx scripts/dev-db.ts",
    "serve": "tsx src/server.ts",
    "seed": "tsx scripts/seed.ts",
    "seed:demo": "tsx scripts/seed-premium-demo.ts",
    "smoke": "tsx scripts/smoke.ts",
    "smoke:socket": "tsx scripts/socket-smoke.ts",
    "test": "jest --runInBand",
    "test:watch": "jest --runInBand --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "flowos",
    "queue",
    "express",
    "mongodb",
    "mongoose"
  ],
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "firebase-admin": "^13.10.0",
    "groq-sdk": "^1.2.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.24.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "socket.io": "^4.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^9.39.4",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.4.3",
    "prettier": "^3.8.3",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
